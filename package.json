{
  "name": "@doryski/node-queue",
  "version": "0.2.0",
  "description": "CPU-based process queue daemon that throttles test runners (vitest, jest, playwright) to prevent system overload. macOS only.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "bin": {
    "node-queue": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "build:shims": "tsx src/build.ts",
    "dev": "tsc --watch",
    "start": "tsx src/cli.ts start",
    "daemon": "tsx src/daemon.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src",
    "format": "prettier --write src",
    "release": "tsx scripts/release.ts",
    "prepublishOnly": "pnpm build"
  },
  "keywords": [
    "queue",
    "process",
    "cpu",
    "throttle",
    "test-runner",
    "vitest",
    "jest",
    "playwright",
    "daemon"
  ],
  "author": "Dominik Rycharski (https://github.com/doryski)",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Doryski/node-queue.git"
  },
  "homepage": "https://github.com/Doryski/node-queue#readme",
  "bugs": {
    "url": "https://github.com/Doryski/node-queue/issues"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@clack/prompts": "^0.7.0",
    "commander": "^12.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^20.0.0",
    "@typescript-eslint/eslint-plugin": "^8.58.2",
    "@typescript-eslint/parser": "^8.58.2",
    "esbuild": "^0.20.0",
    "eslint": "^10.2.0",
    "prettier": "^3.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.0.0",
    "typescript-eslint": "^8.58.2",
    "vitest": "^1.0.0"
  }
}
